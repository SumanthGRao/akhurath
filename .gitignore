.env
/*.log
.DS_Store

# Install-specific settings (SMTP, flags, etc.) — never commit; use includes/config.example.php as template
includes/config.php

# Local MySQL credentials (Hostinger / XAMPP) — never commit
config/database.local.php

# Ignore everything under data/, then allow committed templates & config
/data/**
!/data/
!/data/.htaccess
!/data/*.example.php
!/data/tasks.example.json
!/data/customer-emails.example.json
!/data/editor-attendance.example.json
!/data/editor-leave.example.json
!/data/admins.php
